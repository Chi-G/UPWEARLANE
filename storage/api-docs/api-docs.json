    "components": {
        "schemas": {
            "Product": {
                "title": "Product",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "price": {
                        "type": "number",
                        "format": "float"
                    },
                    "image": {
                        "type": "string"
                    },
                    "category": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "Category": {
                "title": "Category",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "slug": {
                        "type": "string"
                    },
                    "icon": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "Review": {
                "title": "Review",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "user": {
                        "type": "string"
                    },
                    "rating": {
                        "type": "integer"
                    },
                    "comment": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "OrderSchema": {
                "title": "Order",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "order_number": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string"
                    },
                    "total": {
                        "type": "number",
                        "format": "float"
                    },
                    "currency": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "PaymentIntentRequest": {
                "title": "Payment Intent Request",
                "required": [
                    "items",
                    "shipping_address",
                    "shipping_method",
                    "currency",
                    "subtotal",
                    "shipping_cost",
                    "total"
                ],
                "properties": {
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    },
                    "shipping_address": {
                        "type": "object"
                    },
                    "shipping_method": {
                        "type": "object"
                    },
                    "currency": {
                        "type": "string",
                        "enum": [
                            "USD",
                            "NGN",
                            "GBP",
                            "CAD"
                        ]
                    },
                    "subtotal": {
                        "type": "number",
                        "format": "float"
                    },
                    "shipping_cost": {
                        "type": "number",
                        "format": "float"
                    },
                    "tax": {
                        "type": "number",
                        "format": "float"
                    },
                    "total": {
                        "type": "number",
                        "format": "float"
                    }
                },
                "type": "object"
            }
        }
